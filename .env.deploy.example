# ---------- 后端与数据库 ----------
DATABASE_URL=sqlite:////app/data/local_dev.sqlite3
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8002
API_BASE_URL=http://backend-api:8002
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200
CLEANUP_DAYS_DEFAULT=30

# ---------- 调度 ----------
AUTO_START_SCHEDULER=false
SCHEDULER_CHECK_INTERVAL=300
DB_SCHEDULER_BATCH_SIZE=10
DB_SCHEDULER_RECOVER_TIMEOUT=3600

# ---------- AI ----------
AI_PROVIDER=openai
ENABLE_AI_POLISH=true
AI_TIMEOUT=180
WHISPER_MODEL=base
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://code.rayinai.com/v1
OPENAI_MODEL=gpt-5.4
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ---------- 飞书 ----------
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_BITABLE_TABLE_ID=your_table_id

# ---------- 路径 ----------
DOWNLOAD_PATH=/app/downloads
OUTPUT_PATH=/app/outputs
LOG_PATH=/app/logs
COOKIES_FILE=/app/cookies.txt
MAX_RETRIES=3
