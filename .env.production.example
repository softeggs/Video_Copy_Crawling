# ---------- 镜像 ----------
BACKEND_API_IMAGE=registry.example.com/video-copy-crawling/backend-api:v0.1.0
DB_SCHEDULER_IMAGE=registry.example.com/video-copy-crawling/db-scheduler:v0.1.0
WEB_CONSOLE_IMAGE=registry.example.com/video-copy-crawling/web-console:v0.1.0
DEBUG_CONSOLE_IMAGE=registry.example.com/video-copy-crawling/debug-console:v0.1.0
REVERSE_PROXY_IMAGE=nginx:1.27-alpine

# ---------- 端口 ----------
PUBLIC_WEB_PORT=8080
PUBLIC_DEBUG_PORT=8081
BACKEND_PUBLIC_PORT=8002

# ---------- 域名 / 标识 ----------
WEB_SERVER_NAME=app.example.com
DEBUG_SERVER_NAME=debug.example.com
ENVIRONMENT=production

# ---------- 路径 ----------
APP_DATA_ROOT=/srv/video-copy-crawling
NGINX_CONF_PATH=./deploy/nginx/production.conf

# ---------- 业务配置 ----------
DATABASE_URL=sqlite:////app/data/local_dev.sqlite3
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8002
API_BASE_URL=http://backend-api:8002
JWT_SECRET=replace-this-with-a-production-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200
CLEANUP_DAYS_DEFAULT=30

AUTO_START_SCHEDULER=false
SCHEDULER_CHECK_INTERVAL=300
DB_SCHEDULER_BATCH_SIZE=10
DB_SCHEDULER_RECOVER_TIMEOUT=3600

AI_PROVIDER=deepseek
ENABLE_AI_POLISH=true
AI_TIMEOUT=180
WHISPER_MODEL=base
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=
KIMI_API_KEY=
KIMI_BASE_URL=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

DOWNLOAD_PATH=/app/downloads
OUTPUT_PATH=/app/outputs
LOG_PATH=/app/logs
COOKIES_FILE=/app/cookies.txt
MAX_RETRIES=3
