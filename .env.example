# AI 配置（选择其中一个）
# Kimi (Moonshot AI) - 首选，中文效果最佳
KIMI_API_KEY=your-kimi-api-key-here
# Kimi 模型会根据文本长度自动选择：
# - moonshot-v1-8k: 短文本（<2000字符，约5分钟视频）
# - moonshot-v1-32k: 长文本（>=2000字符）

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=  # 可选：使用中转 API 时填写，如 https://api2.qiandao.mom/v1
OPENAI_MODEL=gpt-4-turbo-preview

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# AI 提供商选择: kimi, openai 或 gemini（推荐 kimi，中文效果最佳）
AI_PROVIDER=kimi

# 是否启用 AI 润色: true 或 false
ENABLE_AI_POLISH=true

# AI 处理超时时间（秒）
AI_TIMEOUT=180

# Whisper 配置
WHISPER_MODEL=base
# 可选: tiny, base, small, medium, large

# 飞书配置（可选）
# 配置后可自动同步处理结果到飞书多维表格
# 详细配置指南: READM/FEISHU_QUICKSTART.md
FEISHU_APP_ID=cli_your_app_id              # 飞书应用 ID（从开放平台获取）
FEISHU_APP_SECRET=your_app_secret          # 飞书应用密钥
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token  # 多维表格 APP_TOKEN（从表格 URL 获取）
FEISHU_BITABLE_TABLE_ID=your_table_id      # 数据表 ID（从表格 URL 获取）

# 定时任务配置
AUTO_START_SCHEDULER=false                 # 是否自动启动定时任务: true 或 false
SCHEDULER_CHECK_INTERVAL=300               # 定时任务检查间隔（秒），默认 300 秒（5 分钟）

# 系统配置
DOWNLOAD_PATH=./downloads
OUTPUT_PATH=./outputs
COOKIES_FILE=./cookies.txt
MAX_RETRIES=3
