# AI 閰嶇疆锛堥€夋嫨鍏朵腑涓€涓級
# Kimi (Moonshot AI) - 棣栭€夛紝涓枃鏁堟灉鏈€浣?
KIMI_API_KEY=your-kimi-api-key-here
# Kimi 妯″瀷浼氭牴鎹枃鏈暱搴﹁嚜鍔ㄩ€夋嫨锛?
# - moonshot-v1-8k: 鐭枃鏈紙<2000瀛楃锛岀害5鍒嗛挓瑙嗛锛?
# - moonshot-v1-32k: 闀挎枃鏈紙>=2000瀛楃锛?

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://code.rayinai.com/v1
OPENAI_MODEL=gpt-5.4

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# AI 鎻愪緵鍟嗛€夋嫨: kimi, openai 鎴?gemini锛堟帹鑽?kimi锛屼腑鏂囨晥鏋滄渶浣筹級
AI_PROVIDER=openai

# 鏄惁鍚敤 AI 娑﹁壊: true 鎴?false
ENABLE_AI_POLISH=true

# AI 澶勭悊瓒呮椂鏃堕棿锛堢锛?
AI_TIMEOUT=180

# Whisper 閰嶇疆
WHISPER_MODEL=base
# 鍙€? tiny, base, small, medium, large

# 椋炰功閰嶇疆锛堝彲閫夛級
# 閰嶇疆鍚庡彲鑷姩鍚屾澶勭悊缁撴灉鍒伴涔﹀缁磋〃鏍?
# 璇︾粏閰嶇疆鎸囧崡: READM/FEISHU_QUICKSTART.md
FEISHU_APP_ID=cli_your_app_id              # 椋炰功搴旂敤 ID锛堜粠寮€鏀惧钩鍙拌幏鍙栵級
FEISHU_APP_SECRET=your_app_secret          # 椋炰功搴旂敤瀵嗛挜
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token  # 澶氱淮琛ㄦ牸 APP_TOKEN锛堜粠琛ㄦ牸 URL 鑾峰彇锛?
FEISHU_BITABLE_TABLE_ID=your_table_id      # 鏁版嵁琛?ID锛堜粠琛ㄦ牸 URL 鑾峰彇锛?

# 瀹氭椂浠诲姟閰嶇疆
AUTO_START_SCHEDULER=false                 # 鏄惁鑷姩鍚姩瀹氭椂浠诲姟: true 鎴?false
SCHEDULER_CHECK_INTERVAL=300               # 瀹氭椂浠诲姟妫€鏌ラ棿闅旓紙绉掞級锛岄粯璁?300 绉掞紙5 鍒嗛挓锛?

# 绯荤粺閰嶇疆
DOWNLOAD_PATH=./downloads
OUTPUT_PATH=./outputs
COOKIES_FILE=./cookies.txt
MAX_RETRIES=3

