.source-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 35, 41, 0.05);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.source-title {
  color: #3370ff;
  font-size: 28rpx;
  font-weight: 700;
}

.source-url {
  color: #3370ff;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-all;
}

.source-button {
  margin: 0;
  background: #eef5ff;
  color: #3370ff;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.source-button::after {
  border: none;
}
