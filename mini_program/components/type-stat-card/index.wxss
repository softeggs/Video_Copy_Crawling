.stat-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 35, 41, 0.05);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stat-label {
  color: #646a73;
  font-size: 24rpx;
}

.stat-count {
  color: #5e5ce6;
  font-size: 40rpx;
  font-weight: 700;
}
