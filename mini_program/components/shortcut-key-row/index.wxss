.key-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(31, 35, 41, 0.05);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.key-name {
  font-size: 28rpx;
  font-weight: 600;
}

.key-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.key-badge.active {
  color: #52c41a;
  background: rgba(82, 196, 26, 0.12);
}

.key-badge.revoked {
  color: #646a73;
  background: rgba(100, 106, 115, 0.12);
}

.key-meta {
  color: #646a73;
  font-size: 24rpx;
}

.revoke-button {
  margin: 12rpx 0 0;
  background: #fff1f0;
  color: #f5222d;
  border-radius: 16rpx;
}

.revoke-button::after {
  border: none;
}
