.login-scroll {
  height: 100vh;
}

.login-page {
  min-height: 100vh;
}

.login-stack {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-top: 48rpx;
  padding-bottom: 260rpx;
  box-sizing: border-box;
}

.brand-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding-top: 24rpx;
}

.brand-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5e5ce6, #3370ff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
}

.brand-subtitle,
.login-footer,
.field-label {
  color: #646a73;
  font-size: 24rpx;
}

.field-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}

.login-card {
  width: 100%;
}

.login-input {
  display: block;
  width: 100%;
  min-height: 88rpx;
  color: #1f2329;
  font-size: 28rpx;
  line-height: 44rpx;
  box-sizing: border-box;
}

.login-button {
  display: block;
  width: 100%;
  box-sizing: border-box;
}

.login-footer {
  text-align: center;
  padding-bottom: 24rpx;
}
